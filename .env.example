# ================================================================
# WTS 환경변수 예시 파일
# 사용법: cp .env.example .env  → .env 에 실제 값 입력
#
# ⚠️  .env 파일은 .gitignore 에 포함되어 있습니다.
#     절대로 실제 키를 이 파일(.env.example)에 입력하지 마세요.
# ================================================================

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=1234
MYSQL_DATABASE=stockdb

# ── Google OAuth2 ──────────────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 발급
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Kiwoom 암호화 키 ───────────────────────────────────────────
# 계좌 정보 암호화에 사용되는 내부 키 (임의 문자열 가능)
KIWOOM_ENCRYPTION_SECRET=your-encryption-secret-key
KIWOOM_ENCRYPTION_SALT=your-encryption-salt-value


